# ─── Wallet ────────────────────────────────────────────────────────────
PRIVATE_KEY=your_wallet_private_key_without_0x_prefix

# ─── Base RPC (free via Alchemy / Coinbase / public) ───────────────────
BASE_MAINNET_RPC=https://mainnet.base.org
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Alchemy (recommended for production):
# BASE_MAINNET_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# ─── Contract Config ───────────────────────────────────────────────────
TREASURY_ADDRESS=0xYourTreasuryWalletAddress
DAIMON_ADDRESS=0xDaimonParentTokenOnBase    # set setelah deploy DAIMON

# ─── Basescan API Key ──────────────────────────────────────────────────
# Daftar di: https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key

# ─── Optional ──────────────────────────────────────────────────────────
REPORT_GAS=true
